      "check_timing": "on_game_end",
      "conditions": {
        "at_least_k_of_attrs_gte": {
          "k": 2,
          "attrs": ["stamina", "skill", "mind"],
          "value": 65
        },
        "no_attr_below": 40
      }
    },
    {
      "id": "ach_special_04",
      "name_cn": "无伤之叶",
      "desc_cn": "体能属性全程从未低于25。",
      "check_timing": "on_game_end",
      "conditions": { "attr_never_below": { "stamina": 25 } }
    },
    {
      "id": "ach_special_05",
      "name_cn": "决赛的试炼者",
      "desc_cn": "在决赛中以“属性达标”条件获胜。",
      "check_timing": "on_final_win",
      "conditions": { "final_win_with_requirements_met": true }
    },
    {
      "id": "ach_special_06",
      "name_cn": "经济自由",
      "desc_cn": "理财属性全程从未低于30。",
      "check_timing": "on_game_end",
      "conditions": { "attr_never_below": { "finance": 30 } }
    }
  ],
  "legend": [
    {
      "id": "ach_legend_01",
      "name_cn": "六维的胚芽",
      "desc_cn": "所有属性在50-65之间，总积分≥650，完成全部淬炼，未触发崩解，并以达标条件决赛获胜。",
      "rewards_cn": [
        "专属称号\"均衡胚芽\"",
        "特殊结局水墨动画",
        "深度分析报告（揭示所有隐藏机制）",
        "名字永铭于\"初形殿堂\""
      ],
      "check_timing": "on_game_end",
      "conditions": {
        "all_attrs_between_inclusive": { "min": 50, "max": 65 },
        "total_score_gte": 650,
        "completed_weeks_eq": 12,
        "not_collapsed": true,
        "final_win_with_requirements_met": true
      }
    }
  ]
