      "conditions": { "total_score_gte": 600 }
    },
    {
      "id": "ach_special_02",
      "name_cn": "蜕变的证明",
      "desc_cn": "游戏结束时，最终人格与初始人格完全不同。",
      "check_timing": "on_game_end",
      "conditions": { "personality_end_not_equal_start": true }
    },
    {
      "id": "ach_special_03",
      "name_cn": "潜力的微光",
